# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MongoDB Atlas ────────────────────────────────────────────
# Formato: mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db
MONGODB_URI=mongodb+srv://tuusuario:tupassword@cluster0.xxxxx.mongodb.net/tiquetes_bot

# ── WhatsApp Business API (Meta) ─────────────────────────────
# Token de acceso permanente de tu App en Meta for Developers
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=1234567890123456
# Token inventado por ti para verificar el webhook en Meta
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_2026

# ── Administrador ────────────────────────────────────────────
# Número WhatsApp del administrador (con código de país, sin +)
ADMIN_PHONE=573001234567

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
